# Databricks bundle variables (local dev)
# Copy this file to .env and fill in your values. Never commit .env.
#
# For CI/CD these are set via GitHub secrets (SQL_WAREHOUSE_ID, SERVICE_PRINCIPAL_NAME).

# SQL Warehouse ID for the app to execute Unity Catalog queries (e.g. "16e13f48f7427e3d")
SQL_WAREHOUSE_ID=

# Service principal name/ID for app automation (e.g. "c6f42d70-af80-43ca-9f3a-5bb96c362482")
SERVICE_PRINCIPAL_NAME=
