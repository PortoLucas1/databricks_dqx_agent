# Databricks bundle variables (local dev)
# Copy this file to .env and fill in your values. Never commit .env.
#
# For CI/CD these are set via GitHub secrets (SQL_WAREHOUSE_ID, SERVICE_PRINCIPAL_NAME).

# Required for catalog/schema/table listing (local dev). Not needed when run on Databricks (user token is used).
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Option A: PAT (Personal Access Token) – create in workspace User Settings → Developer → Access tokens
DATABRICKS_TOKEN=

# Option B: OAuth Service Principal (no PAT needed). Create an OAuth secret for the SP in the account/workspace;
# use the secret's client_id and client_secret below. See: docs.databricks.com/en/dev-tools/auth/oauth-m2m.html
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# SQL Warehouse ID for the app to execute Unity Catalog queries (e.g. "16e13f48f7427e3d")
SQL_WAREHOUSE_ID=

# Service principal name/ID for app automation / deployment (e.g. "c6f42d70-af80-43ca-9f3a-5bb96c362482")
SERVICE_PRINCIPAL_NAME=

# Optional: Lakebase for Step 4 (Save to Lakebase). deploy-dev.sh passes these as bundle --var.
# Instance name = first dropdown in Apps UI; database name = second dropdown.
LAKEBASE_INSTANCE_NAME=
LAKEBASE_DATABASE=

# Local dev only: set to true if you see SSL certificate verify failed (e.g. corporate proxy). Never use in production.
# DATABRICKS_TLS_NO_VERIFY=true
